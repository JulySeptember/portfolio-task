# =========================
# app
# =========================

PORT=8080

RUN_MODE=local
APP_ENV=development

ENABLE_DEV_AUTH_BYPASS=true
ENABLE_SWAGGER=true

# =========================
# database
# =========================

DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=taskdb
DB_USER=root
DB_PASSWORD=change_me

# example:
# root:password@tcp(127.0.0.1:3307)/taskdb?parseTime=true&charset=utf8mb4&loc=UTC
DB_DSN=root:change_me@tcp(127.0.0.1:3307)/taskdb?parseTime=true&charset=utf8mb4&loc=UTC

# connection pool
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=10

# recycle connections periodically
DB_CONN_MAX_LIFETIME=5m

# close idle connections
DB_CONN_MAX_IDLE_TIME=3m

# startup ping timeout
DB_PING_TIMEOUT=3s

# =========================
# cors
# =========================

# comma separated exact origins
CORS_ALLOW_ORIGINS=http://localhost:3000

