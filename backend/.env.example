# =========================
# app
# =========================

PORT=8080

RUN_MODE=local
APP_ENV=development

# local development only
# NEVER enable in production
ENABLE_DEV_AUTH_BYPASS=false

# swagger
ENABLE_SWAGGER=true

# =========================
# database
# =========================

# example:
# root:password@tcp(127.0.0.1:3306)/taskdb?parseTime=true&charset=utf8mb4&loc=UTC
DB_DSN=root:change_me@tcp(127.0.0.1:3306)/taskdb?parseTime=true&charset=utf8mb4&loc=UTC

# connection pool
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=10

# recycle connections periodically
DB_CONN_MAX_LIFETIME=5m

# close idle connections
DB_CONN_MAX_IDLE_TIME=3m

# startup ping timeout
DB_PING_TIMEOUT=3s

# =========================
# cors
# =========================

# comma separated exact origins
CORS_ALLOW_ORIGINS=http://localhost:3000

# =========================
# aws cognito
# =========================

AWS_REGION=ap-northeast-1

COGNITO_USER_POOL_ID=your_user_pool_id
COGNITO_APP_CLIENT_ID=your_app_client_id