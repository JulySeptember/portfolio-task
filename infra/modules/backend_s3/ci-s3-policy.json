{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCIUpload",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:PutObjectAcl",
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::your-project-dev-backend-artifacts",
        "arn:aws:s3:::your-project-dev-backend-artifacts/*"
      ]
    }
  ]
}
